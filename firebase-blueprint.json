{
  "entities": {
    "User": {
      "title": "User",
      "description": "Platform user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["farmer", "buyer", "logistics"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace product listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "farmerId": { "type": "string" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "farmerId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Marketplace transaction",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "buyerId": { "type": "string" },
        "farmerId": { "type": "string" },
        "logisticsId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"] },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "buyerId", "farmerId", "amount"]
    },
    "Group": {
      "title": "Farmer Group",
      "description": "A community of farmers for joint selling",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "adminId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Marketplace transactions"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Farmer communities"
    }
  }
}
